---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import { fallbackSiteSettings } from "../consts";

export const prerender = true;
---

<BaseLayout title="联系项目 | AstroMeta 设计事务所" description="预约您的初步设计咨询，让我们共同探讨空间的无限可能。">
    <Container className="py-24 lg:py-32">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-20">
            <div class="lg:col-span-5">
                <SectionTitle 
                    title="开启您的项目咨询" 
                    subtitle="联系我们" 
                    align="left"
                    as="h1"
                />
                <p class="text-text-secondary mt-12 mb-16 leading-relaxed">
                    每一个伟大的建筑都始于一次诚挚的对话。无论您的项目处于哪个阶段，我们都期待听取您的想法。
                </p>
                
                <div class="space-y-12">
                    <div>
                        <h4 class="text-[10px] uppercase tracking-widest font-bold mb-4 text-accent-gold">工作室地址</h4>
                        <p class="text-sm leading-relaxed">上海市静安区延安中路 123 号<br />艺术设计中心 4 楼</p>
                    </div>
                    <div>
                        <h4 class="text-[10px] uppercase tracking-widest font-bold mb-4 text-accent-gold">联系方式</h4>
                        <p class="text-sm leading-relaxed">
                            {fallbackSiteSettings.phone && (
                                <span>
                                    T: <a href={`tel:${fallbackSiteSettings.phone.replace(/\s+/g, '')}`} class="hover:text-accent-gold transition-colors no-underline">{fallbackSiteSettings.phone}</a><br />
                                </span>
                            )}
                            {fallbackSiteSettings.email && (
                                <span>
                                    E: <a href={`mailto:${fallbackSiteSettings.email}`} class="hover:text-accent-gold transition-colors no-underline">{fallbackSiteSettings.email}</a><br />
                                </span>
                            )}
                            {fallbackSiteSettings.whatsapp && (
                                <span>
                                    W: <a href={fallbackSiteSettings.whatsapp} target="_blank" rel="noreferrer" class="hover:text-accent-gold transition-colors no-underline">WhatsApp</a>
                                </span>
                            )}
                        </p>
                    </div>
                    <div>
                        <h4 class="text-[10px] uppercase tracking-widest font-bold mb-4 text-accent-gold">关注我们</h4>
                        <div class="flex gap-6 mt-4">
                            {fallbackSiteSettings.social?.instagram && (
                                <a href={fallbackSiteSettings.social.instagram} target="_blank" rel="noreferrer" class="text-xs uppercase tracking-widest hover:text-accent-gold transition-colors no-underline">Instagram</a>
                            )}
                            {fallbackSiteSettings.social?.xhs && (
                                <a href={fallbackSiteSettings.social.xhs} target="_blank" rel="noreferrer" class="text-xs uppercase tracking-widest hover:text-accent-gold transition-colors no-underline">Xiaohongshu</a>
                            )}
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="lg:col-span-7">
                <form id="contact-form" class="space-y-10 bg-white p-12 border border-border-soft" method="post" action="/api/forms/contact" data-endpoint="/api/forms/contact">
                    <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" />
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <div class="flex flex-col gap-2">
                            <label for="contact-name" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">姓名</label>
                            <input id="contact-name" name="name" type="text" autocomplete="name" aria-required="true" required class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent" placeholder="您的姓名" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label for="contact-phone" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">联系电话</label>
                            <input id="contact-phone" name="phone" type="tel" autocomplete="tel" inputmode="tel" class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent" placeholder="您的电话" />
                        </div>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label for="contact-email" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">电子邮箱</label>
                        <input id="contact-email" name="email" type="email" autocomplete="email" inputmode="email" aria-required="true" required class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent" placeholder="email@example.com" />
                    </div>
                    <div class="flex flex-col gap-2">
                        <label for="contact-project-type" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">项目类型</label>
                        <select id="contact-project-type" name="projectType" class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent appearance-none">
                            <option>私人住宅</option>
                            <option>商业空间</option>
                            <option>文化建筑</option>
                            <option>旧城改造</option>
                            <option>其他</option>
                        </select>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label for="contact-message" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">项目描述</label>
                        <textarea id="contact-message" name="message" rows="4" aria-required="true" required class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent" placeholder="请简要描述您的项目需求..."></textarea>
                    </div>
                    <input type="hidden" name="sourceUrl" value={Astro.url.href} />
                    <input type="hidden" name="locale" value={(Astro as any).currentLocale ?? 'zh-cn'} />
                    <button type="submit" class="btn-primary w-full" aria-label="提交咨询表单">提交咨询请求</button>
                    <p id="form-status" class="text-xs text-text-secondary hidden" role="status" aria-live="polite" aria-atomic="true"></p>
                </form>
            </div>
        </div>
    </Container>
</BaseLayout>

<script>
  const formEl = document.getElementById('contact-form');
  const statusEl = document.getElementById('form-status');
  const form = formEl instanceof HTMLFormElement ? formEl : null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const payload = Object.fromEntries(fd.entries());

    statusEl?.classList.remove('hidden');
    if (statusEl) statusEl.textContent = '正在提交...';

    try {
      const endpoint = form.dataset.endpoint || form.getAttribute('action') || '/api/forms/contact';
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await res.json().catch(() => ({}));
      if (res.ok && data?.success) {
        if (statusEl) statusEl.textContent = '提交成功，我们将尽快与您联系。';
        form.reset();
      } else {
        if (statusEl) statusEl.textContent = '提交失败，请稍后重试或通过邮箱/WhatsApp 联系我们。';
      }
    } catch {
      if (statusEl) statusEl.textContent = '网络异常，请稍后重试或通过邮箱/WhatsApp 联系我们。';
    }
  });
</script>
