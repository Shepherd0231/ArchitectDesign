---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/cards/BlogCard.astro";
import CTA from "../../components/sections/CTA.astro";
import Container from "../../components/ui/Container.astro";
import SectionTitle from "../../components/ui/SectionTitle.astro";

import { getCollection } from "astro:content";
import { fetchPosts, sanityAvailable } from '../../lib/sanity/api';
import { normalizeSanityLocale } from '../../lib/sanity/env';
import { resolveImageUrl } from "../../lib/content/images";
import { getLocaleFromPathname, localizePath } from "../../lib/i18n/routing";
import { pickLocale } from "../../lib/i18n/content";

const lang = getLocaleFromPathname(Astro.url.pathname);
const locale = normalizeSanityLocale(lang);

let posts = [] as Array<{
  slug: string;
  title: string;
  description: string;
  publishDate: string;
  author?: string;
  tags?: string[];
  coverImage: string;
  coverImageMeta?: { alt?: string };
}>;

if (sanityAvailable()) {
  const sanityPosts = await fetchPosts(locale);
  posts = sanityPosts.length
    ? sanityPosts
    : pickLocale(await getCollection('blog'), lang).map((entry) => ({
        slug: entry.id,
        title: entry.data.title,
        description: entry.data.description,
        publishDate: entry.data.publishDate.toISOString().slice(0, 10),
        author: entry.data.author,
        tags: entry.data.tags,
        coverImage: resolveImageUrl(entry.data.coverImage) ?? entry.data.coverImage,
        coverImageMeta: entry.data.coverImageMeta,
      }));
} else {
  posts = pickLocale(await getCollection('blog'), lang).map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
    description: entry.data.description,
    publishDate: entry.data.publishDate.toISOString().slice(0, 10),
    author: entry.data.author,
    tags: entry.data.tags,
    coverImage: resolveImageUrl(entry.data.coverImage) ?? entry.data.coverImage,
    coverImageMeta: entry.data.coverImageMeta,
  }));
}

export const prerender = true;

const ogImage = posts[0]?.coverImage;
---

<BaseLayout title="设计视界 | AstroMeta 事务所" description="关于建筑、材料、光影与空间的研究与思考，记录我们的设计方法与灵感来源。" image={ogImage}>
    <Container className="py-24 lg:py-32">
        <SectionTitle 
            title="关于空间的思考与记录" 
            subtitle="设计视界" 
            align="left" 
            as="h1"
            className="mb-16"
        />

        <div class="space-y-2">
            {posts.map(post => (
                <BlogCard post={post} slug={post.slug} />
            ))}
        </div>
    </Container>

    <CTA 
        title="订阅我们的设计通讯" 
        description="获取最新的项目动态、设计思考与行业洞见。" 
        buttonText="开始订阅" 
        buttonLink={localizePath("/contact", lang)}
    />
</BaseLayout>
