---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import SectionTitle from "../../components/ui/SectionTitle.astro";
import { fallbackSiteSettings } from "../../consts";

export const prerender = true;

const lang = "en";
---

<BaseLayout
  title="Contact | AstroMeta"
  description="Book an initial consultation and explore what your space can become."
  locale={lang}
>
  <Container className="py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-20">
      <div class="lg:col-span-5">
        <SectionTitle title="Start a conversation" subtitle="Contact" align="left" as="h1" />
        <p class="text-text-secondary mt-12 mb-16 leading-relaxed">
          Every great project starts with an honest dialogue. No matter what stage you’re at, we’d love to hear from you.
        </p>

        <div class="space-y-12">
          <div>
            <h4 class="text-[10px] uppercase tracking-widest font-bold mb-4 text-accent-gold">Studio Address</h4>
            <p class="text-sm leading-relaxed">
              Jing’an District, Shanghai<br />
              No.123 Yan’an Middle Road, Floor 4
            </p>
          </div>
          <div>
            <h4 class="text-[10px] uppercase tracking-widest font-bold mb-4 text-accent-gold">Contact</h4>
            <p class="text-sm leading-relaxed">
              {fallbackSiteSettings.phone && (
                <span>
                  T:{" "}
                  <a
                    href={`tel:${fallbackSiteSettings.phone.replace(/\s+/g, "")}`}
                    class="hover:text-accent-gold transition-colors no-underline"
                  >
                    {fallbackSiteSettings.phone}
                  </a>
                  <br />
                </span>
              )}
              {fallbackSiteSettings.email && (
                <span>
                  E:{" "}
                  <a
                    href={`mailto:${fallbackSiteSettings.email}`}
                    class="hover:text-accent-gold transition-colors no-underline"
                  >
                    {fallbackSiteSettings.email}
                  </a>
                  <br />
                </span>
              )}
              {fallbackSiteSettings.whatsapp && (
                <span>
                  W:{" "}
                  <a
                    href={fallbackSiteSettings.whatsapp}
                    target="_blank"
                    rel="noreferrer"
                    class="hover:text-accent-gold transition-colors no-underline"
                  >
                    WhatsApp
                  </a>
                </span>
              )}
            </p>
          </div>
          <div>
            <h4 class="text-[10px] uppercase tracking-widest font-bold mb-4 text-accent-gold">Follow</h4>
            <div class="flex gap-6 mt-4">
              {fallbackSiteSettings.social?.instagram && (
                <a
                  href={fallbackSiteSettings.social.instagram}
                  target="_blank"
                  rel="noreferrer"
                  class="text-xs uppercase tracking-widest hover:text-accent-gold transition-colors no-underline"
                >
                  Instagram
                </a>
              )}
              {fallbackSiteSettings.social?.xhs && (
                <a
                  href={fallbackSiteSettings.social.xhs}
                  target="_blank"
                  rel="noreferrer"
                  class="text-xs uppercase tracking-widest hover:text-accent-gold transition-colors no-underline"
                >
                  Xiaohongshu
                </a>
              )}
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <form
          id="contact-form"
          class="space-y-10 bg-white p-12 border border-border-soft"
          method="post"
          action="/api/forms/contact"
          data-endpoint="/api/forms/contact"
        >
          <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="flex flex-col gap-2">
              <label for="contact-name" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">
                Name
              </label>
              <input
                id="contact-name"
                name="name"
                type="text"
                autocomplete="name"
                aria-required="true"
                required
                class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent"
                placeholder="Your name"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="contact-phone" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">
                Phone
              </label>
              <input
                id="contact-phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                inputmode="tel"
                class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent"
                placeholder="Your phone (optional)"
              />
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <label for="contact-email" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">
              Email
            </label>
            <input
              id="contact-email"
              name="email"
              type="email"
              autocomplete="email"
              inputmode="email"
              aria-required="true"
              required
              class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent"
              placeholder="email@example.com"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="contact-project-type" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">
              Project Type
            </label>
            <select
              id="contact-project-type"
              name="projectType"
              class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent appearance-none"
            >
              <option>Residential</option>
              <option>Commercial</option>
              <option>Cultural</option>
              <option>Renovation</option>
              <option>Other</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label for="contact-message" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">
              Message
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows="4"
              aria-required="true"
              required
              class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent"
              placeholder="Briefly describe your project..."
            ></textarea>
          </div>
          <input type="hidden" name="sourceUrl" value={Astro.url.href} />
          <input type="hidden" name="locale" value={lang} />
          <button type="submit" class="btn-primary w-full" aria-label="Submit contact form">
            Send request
          </button>
          <p id="form-status" class="text-xs text-text-secondary hidden" role="status" aria-live="polite" aria-atomic="true"></p>
        </form>
      </div>
    </div>
  </Container>
</BaseLayout>

<script>
  const formEl = document.getElementById('contact-form');
  const statusEl = document.getElementById('form-status');
  const form = formEl instanceof HTMLFormElement ? formEl : null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const payload = Object.fromEntries(fd.entries());

    statusEl?.classList.remove('hidden');
    if (statusEl) statusEl.textContent = 'Submitting...';

    try {
      const endpoint = form.dataset.endpoint || form.getAttribute('action') || '/api/forms/contact';
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await res.json().catch(() => ({}));
      if (res.ok && data?.success) {
        if (statusEl) statusEl.textContent = 'Submitted. We will reply soon.';
        form.reset();
      } else {
        if (statusEl) statusEl.textContent = 'Submission failed. Please try again later or email us.';
      }
    } catch {
      if (statusEl) statusEl.textContent = 'Network error. Please try again later or email us.';
    }
  });
</script>

