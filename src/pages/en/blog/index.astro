---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogCard from "../../../components/cards/BlogCard.astro";
import CTA from "../../../components/sections/CTA.astro";
import Container from "../../../components/ui/Container.astro";
import SectionTitle from "../../../components/ui/SectionTitle.astro";

import { getCollection } from "astro:content";
import { fetchPosts, sanityAvailable } from "../../../lib/sanity/api";
import { normalizeSanityLocale } from "../../../lib/sanity/env";
import { resolveImageUrl } from "../../../lib/content/images";
import { pickLocale } from "../../../lib/i18n/content";
import { localizePath } from "../../../lib/i18n/routing";

export const prerender = true;

const lang = "en";
const sanityLocale = normalizeSanityLocale(lang);

let posts = [] as Array<{
  slug: string;
  title: string;
  description: string;
  publishDate: string;
  author?: string;
  tags?: string[];
  coverImage: string;
  coverImageMeta?: { alt?: string };
}>;

if (sanityAvailable()) {
  const sanityPosts = await fetchPosts(sanityLocale);
  posts = sanityPosts.length
    ? sanityPosts
    : pickLocale(await getCollection("blog"), lang).map((entry) => ({
        slug: entry.id,
        title: entry.data.title,
        description: entry.data.description,
        publishDate: entry.data.publishDate.toISOString().slice(0, 10),
        author: entry.data.author,
        tags: entry.data.tags,
        coverImage: resolveImageUrl(entry.data.coverImage) ?? entry.data.coverImage,
        coverImageMeta: entry.data.coverImageMeta,
      }));
} else {
  posts = pickLocale(await getCollection("blog"), lang).map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
    description: entry.data.description,
    publishDate: entry.data.publishDate.toISOString().slice(0, 10),
    author: entry.data.author,
    tags: entry.data.tags,
    coverImage: resolveImageUrl(entry.data.coverImage) ?? entry.data.coverImage,
    coverImageMeta: entry.data.coverImageMeta,
  }));
}

const ogImage = posts[0]?.coverImage;
---

<BaseLayout
  title="Insights | AstroMeta"
  description="Research and thoughts on architecture, materials, light, and space — our methods and inspirations."
  image={ogImage}
  locale={lang}
>
  <Container className="py-24 lg:py-32">
    <SectionTitle title="Ideas, process, and inspiration" subtitle="Insights" align="left" as="h1" className="mb-16" />

    <div class="space-y-2">
      {posts.map((post) => (
        <BlogCard post={post} slug={post.slug} />
      ))}
    </div>
  </Container>

  <CTA
    title="Stay updated"
    description="Get new projects, design thinking, and industry notes."
    buttonText="Contact us"
    buttonLink={localizePath("/contact", lang)}
  />
</BaseLayout>

