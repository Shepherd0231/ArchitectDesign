---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/ui/Container.astro";
import ResponsivePicture from "../../../components/ui/ResponsivePicture.astro";
import { getCollection, getEntry, render } from "astro:content";
import { toHTML } from "@portabletext/to-html";
import { fetchPostBySlug, fetchPosts, sanityAvailable } from "../../../lib/sanity/api";
import { normalizeSanityLocale } from "../../../lib/sanity/env";
import { resolveImageUrl } from "../../../lib/content/images";
import { localizePath } from "../../../lib/i18n/routing";

export const prerender = true;

export async function getStaticPaths() {
  const slugs = new Set<string>();

  if (sanityAvailable()) {
    const zh = await fetchPosts("zh");
    zh.forEach((p) => p.slug && slugs.add(p.slug));
    const en = await fetchPosts("en");
    en.forEach((p) => p.slug && slugs.add(p.slug));
  }

  const entries = await getCollection("blog");
  entries.forEach((e) => typeof e.id === "string" && e.id.length > 0 && slugs.add(e.id));

  return Array.from(slugs).map((slug) => ({ params: { slug } }));
}

const lang = "en";
const sanityLocale = normalizeSanityLocale(lang);
const slug = Astro.params.slug as string;

let title = "";
let description = "";
let publishDate = "";
let author: string | undefined;
let tags: string[] | undefined;
let coverImage = "";
let bodyHtml = "";
let Content: any;
let keywords: string[] | string | undefined;
let canonical: string | undefined;
let noindex: boolean | undefined;

if (sanityAvailable()) {
  const post = (await fetchPostBySlug(sanityLocale, slug)) ?? (await fetchPostBySlug("zh", slug));
  if (post) {
    title = post.title;
    description = post.description;
    publishDate = post.publishDate;
    author = post.author;
    tags = post.tags;
    coverImage = post.coverImage;
    bodyHtml = toHTML((post as any).body ?? []);
    keywords = tags;
  } else {
    const entry = await getEntry("blog", slug);
    if (!entry) throw new Error("Post not found");

    title = entry.data.title;
    description = entry.data.description;
    publishDate = entry.data.publishDate.toISOString().slice(0, 10);
    author = entry.data.author;
    tags = entry.data.tags;
    coverImage = resolveImageUrl(entry.data.coverImage) ?? entry.data.coverImage;
    const rendered = await render(entry);
    Content = rendered.Content;
    keywords = entry.data.seo?.keywords ?? tags;
    canonical = entry.data.seo?.canonical;
    noindex = entry.data.seo?.noindex;
  }
} else {
  const entry = await getEntry("blog", slug);
  if (!entry) throw new Error("Post not found");

  title = entry.data.title;
  description = entry.data.description;
  publishDate = entry.data.publishDate.toISOString().slice(0, 10);
  author = entry.data.author;
  tags = entry.data.tags;
  coverImage = resolveImageUrl(entry.data.coverImage) ?? entry.data.coverImage;
  const rendered = await render(entry);
  Content = rendered.Content;
  keywords = entry.data.seo?.keywords ?? tags;
  canonical = entry.data.seo?.canonical;
  noindex = entry.data.seo?.noindex;
}
---

<BaseLayout
  title={`${title} | Insights`}
  description={description}
  image={coverImage}
  keywords={keywords}
  canonical={canonical}
  noindex={noindex}
  locale={lang}
>
  <div class="pt-32 pb-16 bg-light-bg border-b border-border-soft">
    <Container className="max-w-4xl text-center">
      <div class="flex justify-center gap-4 mb-6 text-[10px] uppercase tracking-widest text-accent-gold font-bold">
        <span>{publishDate}</span>
        <span>/</span>
        <span>{author}</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-heading leading-tight mb-8">{title}</h1>
      <p class="text-xl text-text-secondary leading-relaxed">{description}</p>
    </Container>
  </div>

  <Container className="py-20 max-w-3xl">
    <div class="mb-12 aspect-video overflow-hidden">
      <ResponsivePicture
        src={coverImage}
        alt={title}
        priority={true}
        width={1600}
        height={900}
        sizes="(min-width: 768px) 768px, 100vw"
        className="w-full h-full object-cover"
      />
    </div>
    <article class="prose prose-lg prose-slate max-w-none prose-headings:font-heading prose-img:rounded-none">
      {bodyHtml ? <div set:html={bodyHtml} /> : Content ? <Content /> : null}
    </article>

    <div class="mt-16 pt-8 border-t border-border-soft flex justify-between items-center">
      <a
        href={localizePath("/blog", lang)}
        class="text-xs uppercase tracking-widest font-bold text-text-secondary hover:text-primary-brand transition-colors"
      >
        &larr; Back to list
      </a>
      <div class="flex gap-2">
        {tags?.map((tag) => (
          <span class="text-[10px] uppercase tracking-widest px-3 py-1 border border-border-soft text-text-secondary">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </Container>
</BaseLayout>

