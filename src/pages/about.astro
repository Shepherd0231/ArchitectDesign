---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import ResponsivePicture from "../components/ui/ResponsivePicture.astro";
const aboutImage = "https://images.unsplash.com/photo-1507413245164-6160d8298b31?auto=format&fit=crop&w=1200&q=80";

export const prerender = true;
---

<BaseLayout title="关于我们 | AstroMeta 设计事务所" description="了解我们的设计哲学、团队成员以及我们如何通过建筑改变生活。" image={aboutImage}>
    <Container className="py-24 lg:py-32">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
            <div class="lg:col-span-6">
                <SectionTitle 
                    title="以纯粹之名，重塑空间" 
                    subtitle="我们的故事" 
                    align="left"
                    as="h1"
                />
                <div class="mt-12 space-y-6 text-text-secondary leading-relaxed">
                    <p>
                        AstroMeta 成立于 2015 年，是一家立足于上海的精品建筑设计事务所。我们深信，建筑不仅仅是砖石的堆砌，更是光影、材质与情感的容器。
                    </p>
                    <p>
                        在过去的十年里，我们拒绝盲从流行趋势，坚持“由内而外”的设计逻辑。从私人住宅到商业空间，我们致力于为每一个项目寻找其独特的空间秩序，创造出静谧、永恒且具有人文关怀的建筑作品。
                    </p>
                </div>
                
                <div class="mt-16 grid grid-cols-2 gap-12 border-t border-border-soft pt-12">
                    <div>
                        <h4 class="text-[10px] uppercase tracking-widest font-bold mb-4 text-accent-gold">设计理念</h4>
                        <p class="text-sm">极简、纯粹、永恒、自然</p>
                    </div>
                    <div>
                        <h4 class="text-[10px] uppercase tracking-widest font-bold mb-4 text-accent-gold">服务领域</h4>
                        <p class="text-sm">建筑设计、室内设计、景观规划</p>
                    </div>
                </div>
            </div>
            
            <div class="lg:col-span-6">
                <div class="aspect-[4/5] bg-gray-100 relative overflow-hidden">
                    <ResponsivePicture
                        src={aboutImage}
                        alt="Studio Space"
                        width={960}
                        height={1200}
                        sizes="(min-width: 1024px) 50vw, 100vw"
                        className="w-full h-full object-cover grayscale"
                    />
                </div>
            </div>
        </div>
    </Container>
</BaseLayout>
