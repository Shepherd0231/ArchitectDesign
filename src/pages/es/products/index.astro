---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProductCard from "../../../components/cards/ProductCard.astro";
import CTA from "../../../components/sections/CTA.astro";
import Container from "../../../components/ui/Container.astro";
import SectionTitle from "../../../components/ui/SectionTitle.astro";

import { getCollection } from "astro:content";
import { fetchCases, sanityAvailable } from "../../../lib/sanity/api";
import { resolveImageUrl } from "../../../lib/content/images";
import { pickLocale } from "../../../lib/i18n/content";
import { localizePath } from "../../../lib/i18n/routing";

export const prerender = true;

const lang = "es";

let cases = [] as Array<{
  slug: string;
  title: string;
  description: string;
  isFeatured?: boolean;
  publishDate: string;
  coverImage: string;
  coverImageMeta?: { alt?: string };
  client?: string;
  location?: string;
  year?: number;
  tags?: string[];
}>;

if (sanityAvailable()) {
  const sanityCases = await fetchCases("en");
  cases = sanityCases.length
    ? sanityCases
    : pickLocale(await getCollection("cases"), lang).map((entry) => ({
        slug: entry.id,
        title: entry.data.title,
        description: entry.data.description,
        isFeatured: entry.data.isFeatured,
        publishDate: entry.data.publishDate.toISOString().slice(0, 10),
        coverImage: resolveImageUrl(entry.data.coverImage) ?? entry.data.coverImage,
        coverImageMeta: entry.data.coverImageMeta,
        client: entry.data.client,
        location: entry.data.location,
        year: entry.data.year,
        tags: entry.data.tags,
      }));
} else {
  cases = pickLocale(await getCollection("cases"), lang).map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
    description: entry.data.description,
    isFeatured: entry.data.isFeatured,
    publishDate: entry.data.publishDate.toISOString().slice(0, 10),
    coverImage: resolveImageUrl(entry.data.coverImage) ?? entry.data.coverImage,
    coverImageMeta: entry.data.coverImageMeta,
    client: entry.data.client,
    location: entry.data.location,
    year: entry.data.year,
    tags: entry.data.tags,
  }));
}

const ogImage = cases[0]?.coverImage;
---

<BaseLayout
  title="Proyectos | AstroMeta"
  description="Obras seleccionadas: viviendas minimalistas, espacios comerciales y arquitectura cultural."
  image={ogImage}
  locale={lang}
>
  <Container className="py-24 lg:py-32">
    <SectionTitle title="Obras Seleccionadas" subtitle="Proyectos" align="left" as="h1" className="mb-16" />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {cases.map((caseItem) => (
        <ProductCard product={caseItem} slug={caseItem.slug} />
      ))}
    </div>
  </Container>

  <CTA
    title="Diseñemos tu espacio"
    description="Del concepto a la entrega, acompañamos tu proyecto con un proceso claro."
    buttonText="Contáctanos"
    buttonLink={localizePath("/contact", lang)}
  />
</BaseLayout>

