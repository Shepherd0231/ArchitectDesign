---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import SectionTitle from "../../components/ui/SectionTitle.astro";
import { fallbackSiteSettings } from "../../consts";

export const prerender = true;

const lang = "es";
---

<BaseLayout
  title="Contacto | AstroMeta"
  description="Agenda una consulta inicial y exploremos el potencial de tu espacio."
  locale={lang}
>
  <Container className="py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-20">
      <div class="lg:col-span-5">
        <SectionTitle title="Iniciemos una conversación" subtitle="Contacto" align="left" as="h1" />
        <p class="text-text-secondary mt-12 mb-16 leading-relaxed">
          Todo gran proyecto comienza con un diálogo honesto. Estés en la etapa que estés, nos encantará escucharte.
        </p>

        <div class="space-y-12">
          <div>
            <h4 class="text-[10px] uppercase tracking-widest font-bold mb-4 text-accent-gold">Dirección</h4>
            <p class="text-sm leading-relaxed">
              Distrito Jing’an, Shanghái<br />
              N.º 123 Yan’an Middle Road, Piso 4
            </p>
          </div>
          <div>
            <h4 class="text-[10px] uppercase tracking-widest font-bold mb-4 text-accent-gold">Contacto</h4>
            <p class="text-sm leading-relaxed">
              {fallbackSiteSettings.phone && (
                <span>
                  T:{" "}
                  <a
                    href={`tel:${fallbackSiteSettings.phone.replace(/\s+/g, "")}`}
                    class="hover:text-accent-gold transition-colors no-underline"
                  >
                    {fallbackSiteSettings.phone}
                  </a>
                  <br />
                </span>
              )}
              {fallbackSiteSettings.email && (
                <span>
                  E:{" "}
                  <a
                    href={`mailto:${fallbackSiteSettings.email}`}
                    class="hover:text-accent-gold transition-colors no-underline"
                  >
                    {fallbackSiteSettings.email}
                  </a>
                  <br />
                </span>
              )}
              {fallbackSiteSettings.whatsapp && (
                <span>
                  W:{" "}
                  <a
                    href={fallbackSiteSettings.whatsapp}
                    target="_blank"
                    rel="noreferrer"
                    class="hover:text-accent-gold transition-colors no-underline"
                  >
                    WhatsApp
                  </a>
                </span>
              )}
            </p>
          </div>
          <div>
            <h4 class="text-[10px] uppercase tracking-widest font-bold mb-4 text-accent-gold">Redes</h4>
            <div class="flex gap-6 mt-4">
              {fallbackSiteSettings.social?.instagram && (
                <a
                  href={fallbackSiteSettings.social.instagram}
                  target="_blank"
                  rel="noreferrer"
                  class="text-xs uppercase tracking-widest hover:text-accent-gold transition-colors no-underline"
                >
                  Instagram
                </a>
              )}
              {fallbackSiteSettings.social?.xhs && (
                <a
                  href={fallbackSiteSettings.social.xhs}
                  target="_blank"
                  rel="noreferrer"
                  class="text-xs uppercase tracking-widest hover:text-accent-gold transition-colors no-underline"
                >
                  Xiaohongshu
                </a>
              )}
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <form
          id="contact-form"
          class="space-y-10 bg-white p-12 border border-border-soft"
          method="post"
          action="/api/forms/contact"
          data-endpoint="/api/forms/contact"
        >
          <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="flex flex-col gap-2">
              <label for="contact-name" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">
                Nombre
              </label>
              <input
                id="contact-name"
                name="name"
                type="text"
                autocomplete="name"
                aria-required="true"
                required
                class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent"
                placeholder="Tu nombre"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="contact-phone" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">
                Teléfono
              </label>
              <input
                id="contact-phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                inputmode="tel"
                class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent"
                placeholder="Tu teléfono (opcional)"
              />
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <label for="contact-email" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">
              Email
            </label>
            <input
              id="contact-email"
              name="email"
              type="email"
              autocomplete="email"
              inputmode="email"
              aria-required="true"
              required
              class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent"
              placeholder="email@ejemplo.com"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="contact-project-type" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">
              Tipo de proyecto
            </label>
            <select
              id="contact-project-type"
              name="projectType"
              class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent appearance-none"
            >
              <option>Residencial</option>
              <option>Comercial</option>
              <option>Cultural</option>
              <option>Reforma</option>
              <option>Otro</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label for="contact-message" class="text-[10px] uppercase tracking-widest font-bold text-text-secondary">
              Mensaje
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows="4"
              aria-required="true"
              required
              class="border-b border-border-soft py-2 focus:border-primary-brand outline-none transition-colors bg-transparent"
              placeholder="Describe brevemente tu proyecto..."
            ></textarea>
          </div>
          <input type="hidden" name="sourceUrl" value={Astro.url.href} />
          <input type="hidden" name="locale" value={lang} />
          <button type="submit" class="btn-primary w-full" aria-label="Enviar formulario de contacto">
            Enviar solicitud
          </button>
          <p id="form-status" class="text-xs text-text-secondary hidden" role="status" aria-live="polite" aria-atomic="true"></p>
        </form>
      </div>
    </div>
  </Container>
</BaseLayout>

<script>
  const formEl = document.getElementById('contact-form');
  const statusEl = document.getElementById('form-status');
  const form = formEl instanceof HTMLFormElement ? formEl : null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const payload = Object.fromEntries(fd.entries());

    statusEl?.classList.remove('hidden');
    if (statusEl) statusEl.textContent = 'Enviando...';

    try {
      const endpoint = form.dataset.endpoint || form.getAttribute('action') || '/api/forms/contact';
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await res.json().catch(() => ({}));
      if (res.ok && data?.success) {
        if (statusEl) statusEl.textContent = 'Enviado. Te responderemos pronto.';
        form.reset();
      } else {
        if (statusEl) statusEl.textContent = 'No se pudo enviar. Inténtalo de nuevo más tarde o escríbenos por email.';
      }
    } catch {
      if (statusEl) statusEl.textContent = 'Error de red. Inténtalo de nuevo más tarde o escríbenos por email.';
    }
  });
</script>

