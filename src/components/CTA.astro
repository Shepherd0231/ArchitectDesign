---
const { title, description, buttonText, buttonLink } = Astro.props;
---

<section class="section-padding bg-dark-bg rounded-[2.5rem] my-12 relative overflow-hidden text-center lg:text-left">
    <!-- Decorative background elements -->
    <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary-red/20 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-white/5 rounded-full blur-3xl"></div>
    
    <div class="container-custom relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
            <div class="lg:col-span-8">
                <h2 class="text-3xl md:text-5xl lg:text-6xl text-white mb-6 leading-tight">
                    {title}
                </h2>
                <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto lg:mx-0">
                    {description}
                </p>
            </div>
            <div class="lg:col-span-4 flex justify-center lg:justify-end">
                <a href={buttonLink} class="btn-primary px-10 py-5 text-lg shadow-xl shadow-primary-red/30 no-underline">
                    {buttonText}
                </a>
            </div>
        </div>
    </div>
</section>
