---
import ResponsivePicture from "../ui/ResponsivePicture.astro";
import { getLocaleFromPathname, localizePath } from "../../lib/i18n/routing";
import { t } from "../../lib/i18n/messages";

interface Props {
  post: {
    title: string;
    description: string;
    publishDate: string;
    coverImage: string;
    coverImageMeta?: {
      alt?: string;
    };
  };
  slug: string;
}

const { post, slug } = Astro.props;
const locale = getLocaleFromPathname(Astro.url.pathname);
const href = localizePath(`/blog/${slug}`, locale);
---

<article class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start border-b border-border-soft py-12 last:border-0 group">
  <a href={href} class="md:col-span-4 block aspect-[4/3] overflow-hidden bg-gray-100">
    <ResponsivePicture
      src={post.coverImage}
      alt={post.coverImageMeta?.alt ?? post.title}
      width={1200}
      height={900}
      sizes="(min-width: 768px) 33vw, 100vw"
      className="w-full h-full object-cover grayscale-[0.2] group-hover:scale-105 group-hover:grayscale-0 transition-all duration-1000"
    />
  </a>
  <div class="md:col-span-8">
    <time class="text-[10px] uppercase tracking-widest font-bold text-accent-gold block mb-4">
      {post.publishDate}
    </time>
    <h3 class="text-2xl md:text-4xl font-heading mb-5 leading-tight group-hover:text-primary-brand transition-colors">
      <a href={href} class="no-underline text-inherit">{post.title}</a>
    </h3>
    <p class="text-text-secondary text-base leading-relaxed mb-8 line-clamp-2">{post.description}</p>
    <a href={href} class="inline-flex items-center text-[10px] uppercase tracking-[0.2em] font-bold text-text-secondary hover:text-primary-brand transition-colors group/link no-underline">
      {t(locale, 'blog', 'readMore')}
      <span class="ml-2 group-hover/link:translate-x-1 transition-transform">&rarr;</span>
    </a>
  </div>
</article>
