---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center" | "right";
  className?: string;
  as?: "h1" | "h2" | "h3";
}

const { title, subtitle, align = "center", className = "", as = "h2" } = Astro.props as Props;

const alignClasses = {
  left: "text-left items-start",
  center: "text-center items-center",
  right: "text-right items-end"
};

const Tag = as;
---

<div class={`flex flex-col ${alignClasses[align]} ${className}`}>
  {subtitle && (
    <span class="text-accent-gold text-[10px] uppercase tracking-[0.4em] mb-4 font-body font-semibold">
      {subtitle}
    </span>
  )}
  <Tag class="text-3xl md:text-5xl lg:text-6xl font-heading leading-tight max-w-4xl">
    {title}
  </Tag>
  <div class="w-16 h-px bg-primary-brand mt-8"></div>
</div>
