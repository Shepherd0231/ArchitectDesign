---
import ResponsivePicture from "./ui/ResponsivePicture.astro";

const { title, description, image, slug } = Astro.props;
---

<article class="card flex flex-col h-full overflow-hidden">
    <div class="aspect-video w-full overflow-hidden rounded-xl mb-4 bg-gray-100">
        <ResponsivePicture src={image} alt={title} width={1200} height={675} sizes="(min-width: 768px) 50vw, 100vw" className="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
    </div>
    <div class="flex flex-col flex-grow">
        <h3 class="text-xl font-bold mb-2">{title}</h3>
        <p class="text-text-secondary text-sm mb-6 flex-grow">{description}</p>
        <a href={`/products/${slug}/`} class="btn-secondary py-2 text-sm w-full no-underline">View Details</a>
    </div>
</article>
