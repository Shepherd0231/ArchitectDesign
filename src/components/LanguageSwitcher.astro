---
import { getLocaleFromPathname, localizePath, supportedLocales } from '../lib/i18n/routing';
import { getLocaleLabel, t } from '../lib/i18n/messages';

const pathname = Astro.url.pathname;
const current = getLocaleFromPathname(pathname);
const ariaLabel = t(current, 'language', 'label');
---

<nav aria-label={ariaLabel} class="flex items-center gap-3">
  {supportedLocales.map((loc) => (
    <a
      href={localizePath(pathname, loc)}
      aria-current={loc === current ? 'page' : undefined}
      class={`text-[10px] uppercase tracking-[0.2em] font-semibold no-underline transition-colors ${
        loc === current ? 'text-accent-gold' : 'text-text-secondary hover:text-accent-gold'
      }`}
    >
      {getLocaleLabel(loc)}
    </a>
  ))}
</nav>

