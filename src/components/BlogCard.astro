---
import ResponsivePicture from "./ui/ResponsivePicture.astro";

const { title, description, date, image, slug } = Astro.props;
---

<article class="flex flex-col md:flex-row gap-6 md:gap-8 items-center border-b border-gray-100 py-10 last:border-0 group">
    <div class="w-full md:w-1/3 aspect-[4/3] overflow-hidden rounded-2xl bg-gray-100">
        <ResponsivePicture src={image} alt={title} width={1200} height={900} sizes="(min-width: 768px) 33vw, 100vw" className="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
    </div>
    <div class="w-full md:w-2/3">
        <time class="text-primary-red font-bold text-sm tracking-wider uppercase mb-2 block">{date}</time>
        <h3 class="text-2xl md:text-3xl font-bold mb-3 group-hover:text-primary-red transition-colors">
            <a href={`/blog/${slug}/`} class="no-underline text-inherit">{title}</a>
        </h3>
        <p class="text-text-secondary text-base mb-6 line-clamp-2">{description}</p>
        <a href={`/blog/${slug}/`} class="text-text-primary font-bold inline-flex items-center group/link no-underline">
            Read More 
            <span class="ml-2 group-hover/link:translate-x-1 transition-transform">&rarr;</span>
        </a>
    </div>
</article>
