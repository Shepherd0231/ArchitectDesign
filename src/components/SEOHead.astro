---
type StructuredData = Record<string, any> | Array<Record<string, any>>;
type AlternateLink = { hreflang: string; href: string };

interface Props {
  title: string;
  description: string;
  image?: string;
  keywords?: string | string[];
  canonical?: string;
  noindex?: boolean;
  siteName?: string;
  locale?: string;
  structuredData?: StructuredData;
  alternates?: AlternateLink[];
  xDefault?: string;
}

const {
  title,
  description,
  image,
  keywords,
  canonical,
  noindex = false,
  siteName,
  locale,
  structuredData,
  alternates,
  xDefault,
} = Astro.props;

const site = (Astro.site ? Astro.site.toString() : '') || Astro.url.origin;
const url = canonical ? new URL(canonical, site).toString() : new URL(Astro.url.pathname, site).toString();
const resolvedImage = image ? new URL(image, site).toString() : undefined;
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
const keywordsContent = Array.isArray(keywords) ? keywords.join(', ') : keywords;

const graph = Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : [];
const jsonLd =
  graph.length > 0
    ? JSON.stringify(graph.length === 1 ? graph[0] : { '@context': 'https://schema.org', '@graph': graph })
    : '';
---

<title>{title}</title>
<meta name="robots" content={robots} />
<meta name="description" content={description} />
{keywordsContent ? <meta name="keywords" content={keywordsContent} /> : null}
<link rel="canonical" href={url} />
{alternates?.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
{xDefault ? <link rel="alternate" hreflang="x-default" href={xDefault} /> : null}

<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
{siteName ? <meta property="og:site_name" content={siteName} /> : null}
{locale ? <meta property="og:locale" content={locale} /> : null}
{resolvedImage ? <meta property="og:image" content={resolvedImage} /> : null}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{resolvedImage ? <meta name="twitter:image" content={resolvedImage} /> : null}

{jsonLd ? <script type="application/ld+json" set:html={jsonLd} /> : null}
