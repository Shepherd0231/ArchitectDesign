---
import Container from "../ui/Container.astro";
import ResponsivePicture from "../ui/ResponsivePicture.astro";

interface Props {
  title?: string;
  subtitle?: string;
  image?: string;
  badgeText?: string;
  primaryCtaText?: string;
  primaryCtaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const { 
  title = "Design Beyond Time", 
  subtitle = "Creating spaces that reflect the essence of living.", 
  image = "https://images.unsplash.com/photo-1487958449943-2429e8be8625?auto=format&fit=crop&w=1200&q=80",
  badgeText = "Architecture & Design Studio",
  primaryCtaText = "开始咨询项目",
  primaryCtaHref = "/contact/",
  secondaryCtaText = "浏览设计作品",
  secondaryCtaHref = "/products/",
} = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden bg-light-bg">
    <!-- Background Texture -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none">
        <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
            <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
                <path d="M 10 0 L 0 0 0 10" fill="none" stroke="currentColor" stroke-width="0.5"/>
            </pattern>
            <rect width="100" height="100" fill="url(#grid)" />
        </svg>
    </div>

    <Container className="relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            <div class="lg:col-span-6 max-w-2xl">
                <div class="inline-block px-3 py-1 border border-accent-gold text-accent-gold text-[10px] uppercase tracking-[0.3em] mb-8 animate-fade-in">
                    {badgeText}
                </div>
                <h1 class="text-5xl md:text-7xl lg:text-8xl mb-8 leading-[1.1] animate-slide-up">
                    {title}
                </h1>
                <p class="text-text-secondary text-lg md:text-xl mb-12 max-w-lg leading-relaxed animate-slide-up delay-200">
                    {subtitle}
                </p>
                <div class="flex flex-col sm:flex-row gap-6 animate-slide-up delay-400">
                    <a href={primaryCtaHref} class="btn-primary">{primaryCtaText}</a>
                    <a href={secondaryCtaHref} class="btn-secondary">{secondaryCtaText}</a>
                </div>
            </div>
            
            <div class="lg:col-span-6 relative group">
                <div class="aspect-[4/5] overflow-hidden">
                    <ResponsivePicture
                        src={image}
                        alt={title}
                        width={960}
                        height={1200}
                        sizes="(min-width: 1024px) 50vw, 100vw"
                        priority={true}
                        className="w-full h-full object-cover grayscale-[0.2] group-hover:scale-105 transition-transform duration-1000"
                    />
                </div>
                <!-- Decorative element -->
                <div class="absolute -bottom-10 -left-10 w-40 h-40 border border-border-soft -z-10 hidden lg:block group-hover:translate-x-4 group-hover:translate-y-4 transition-transform duration-700"></div>
            </div>
        </div>
    </Container>
</section>

<style>
    @keyframes fade-in {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    @keyframes slide-up {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in { animation: fade-in 1.2s ease-out forwards; }
    .animate-slide-up { opacity: 0; animation: slide-up 1s ease-out forwards; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-400 { animation-delay: 0.4s; }
</style>
